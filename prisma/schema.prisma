// Prisma schema for Ovenisto POS System
// Generated from BACKEND_DEVELOPMENT_GUIDE.md
// Covers all 10 implementation phases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// PHASE 1: Auth & Users
// =============================================

model Outlet {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(20)
  address   String?
  city      String?  @db.VarChar(50)
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  users            User[]
  settings         Settings[]
  loyaltySettings  LoyaltySettings[]
  transfersFrom    Transfer[]        @relation("TransferFrom")
  transfersTo      Transfer[]        @relation("TransferTo")
  warehouses       Warehouse[]
  orders           Order[]           @relation("OrderOutlet")
  stockAdjustments StockAdjustment[]
  stockTakes       StockTake[]
  productions      Production[]
  wasteRecords     WasteRecord[]
  shifts           Shift[]
  restaurantTables RestaurantTable[]
  expenses         Expense[]
  purchases        Purchase[]
  reservations      Reservation[]
  customers         Customer[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  staffSchedules    StaffSchedule[]

  @@map("outlets")
}

enum UserRole {
  SUPER_ADMIN      @map("Super Admin")
  ADMIN            @map("Admin")
  MANAGER          @map("Manager")
  CASHIER          @map("Cashier")
  WAITER           @map("Waiter")
  KITCHEN          @map("Kitchen Staff")
  KITCHEN_MANAGER  @map("Kitchen Manager")
  FLOOR_MANAGER    @map("Floor Manager")
  DELIVERY_MANAGER @map("Delivery Manager")
  STORE_MANAGER    @map("Store Manager")
  ACCOUNTANT       @map("Accountant")
  RIDER            @map("Rider")
  CUSTOMER_SCREEN  @map("Customer Screen")
}

model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  role         UserRole
  branch       String?   @db.VarChar(100)
  outletId     String?
  avatar         String?
  status         String    @default("active") @db.VarChar(20)
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  hourlyRate     Decimal?  @db.Decimal(10, 2)
  absencePenalty Decimal?  @db.Decimal(10, 2)

  // Relations
  outlet                   Outlet?           @relation(fields: [outletId], references: [id])
  orders                   Order[]
  stockAdjustments         StockAdjustment[]
  attendanceRecords        AttendanceRecord[]  @relation("UserAttendance")
  leaveRequests            LeaveRequest[]      @relation("UserLeaves")
  leaveReviews             LeaveRequest[]      @relation("LeaveReviewer")
  leaveBalance             LeaveBalance[]
  staffSchedules           StaffSchedule[]     @relation("UserSchedules")
  shifts                   Shift[]
  riderProfile             DeliveryRider?
  managedWarehouses        Warehouse[]       @relation("WarehouseManager")
  challansDispatched       StockChallan[]    @relation("ChallanDispatched")
  challansReceived         StockChallan[]    @relation("ChallanReceived")
  challansCreated          StockChallan[]    @relation("ChallanCreated")
  demandsRequested         StockDemand[]     @relation("DemandRequested")
  demandsApproved          StockDemand[]     @relation("DemandApproved")
  purchaseRequests         PurchaseRequest[] @relation("PurchaseRequestedBy")
  purchaseRequestApprovals PurchaseRequest[] @relation("PurchaseApprovedBy")
  purchasesCreated         Purchase[]        @relation("PurchaseCreatedBy")

  @@map("users")
}

// =============================================
// PHASE 2: Settings
// =============================================

model Settings {
  id                String   @id @default(uuid())
  outletId          String?
  restaurantName    String?  @db.VarChar(100)
  currency          String   @default("Rs.") @db.VarChar(10)
  taxRate           Decimal  @default(16) @db.Decimal(5, 2)
  taxName           String   @default("GST") @db.VarChar(20)
  phone             String?  @db.VarChar(20)
  email             String?  @db.VarChar(100)
  address           String?
  receiptHeader     String?
  tableManagement   Boolean  @default(true)
  onlineOrders      Boolean  @default(true)
  reservations      Boolean  @default(false)
  selfOrderConfig   Json     @default("{}")
  websiteConfig     Json     @default("{}")
  reservationConfig Json     @default("{}")
  shiftConfig       Json     @default("{}")
  graceMinutes      Int      @default(15)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  outlet Outlet? @relation(fields: [outletId], references: [id])

  @@map("settings")
}

// =============================================
// PHASE 3: Menu Management
// =============================================

model FoodCategory {
  id           String @id @default(uuid())
  name         String @db.VarChar(100)
  displayOrder Int    @default(0)
  status       String @default("active") @db.VarChar(20)

  // Relations
  menuItems FoodMenuItem[]

  @@map("food_categories")
}

model FoodMenuItem {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  code           String?  @unique @db.VarChar(20)
  categoryId     String?
  price          Decimal  @db.Decimal(10, 2)
  dineInPrice    Decimal? @db.Decimal(10, 2)
  takeAwayPrice  Decimal? @db.Decimal(10, 2)
  deliveryPrice  Decimal? @db.Decimal(10, 2)
  foodpandaPrice Decimal? @db.Decimal(10, 2)
  available      Boolean  @default(true)
  image          String?
  tags           String[]
  cookingTime    Int      @default(0)
  mealTypeIds    String[]
  createdAt      DateTime @default(now())

  // Relations
  category   FoodCategory?      @relation(fields: [categoryId], references: [id])
  variants   FoodMenuVariant[]
  recipes    FoodRecipe[]
  modifiers  MenuItemModifier[]
  orderItems OrderItem[]

  @@map("food_menu_items")
}

model FoodMenuVariant {
  id             String   @id @default(uuid())
  menuItemId     String
  name           String   @db.VarChar(100)
  price          Decimal  @db.Decimal(10, 2)
  dineInPrice    Decimal? @db.Decimal(10, 2)
  takeAwayPrice  Decimal? @db.Decimal(10, 2)
  deliveryPrice  Decimal? @db.Decimal(10, 2)
  foodpandaPrice Decimal? @db.Decimal(10, 2)
  displayOrder   Int      @default(0)

  // Relations
  menuItem FoodMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  recipes  FoodRecipe[]

  @@map("food_menu_variants")
}

model Modifier {
  id     String  @id @default(uuid())
  name   String  @db.VarChar(100)
  price  Decimal @default(0) @db.Decimal(10, 2)
  type   String? @db.VarChar(20) // addon, removal
  status String  @default("active") @db.VarChar(20)

  // Relations
  menuItems MenuItemModifier[]

  @@map("modifiers")
}

model MenuItemModifier {
  id         String   @id @default(uuid())
  menuItemId String
  modifierId String
  variantIds String[] // empty = all variants; populated = only these variant IDs

  // Relations
  menuItem FoodMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifier Modifier     @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierId])
  @@map("menu_item_modifiers")
}

// =============================================
// PHASE 4: Inventory & Ingredients
// =============================================

model IngredientCategory {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  description String?
  status      String  @default("active") @db.VarChar(20)

  // Relations
  ingredients Ingredient[]

  @@map("ingredient_categories")
}

model IngredientUnit {
  id     String @id @default(uuid())
  name   String @db.VarChar(50)
  symbol String @default("") @db.VarChar(10)
  status String @default("active") @db.VarChar(20)

  // Relations
  ingredients     Ingredient[]
  recipeUsages    FoodRecipe[]
  conversionsFrom UnitConversion[] @relation("FromUnit")
  conversionsTo   UnitConversion[] @relation("ToUnit")

  @@map("ingredient_units")
}

model UnitConversion {
  id         String  @id @default(uuid())
  fromUnitId String
  toUnitId   String
  factor     Decimal @db.Decimal(18, 8)

  fromUnit IngredientUnit @relation("FromUnit", fields: [fromUnitId], references: [id], onDelete: Cascade)
  toUnit   IngredientUnit @relation("ToUnit", fields: [toUnitId], references: [id], onDelete: Cascade)

  @@unique([fromUnitId, toUnitId])
  @@map("unit_conversions")
}

model Ingredient {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  brand          String?  @db.VarChar(100)
  categoryId     String?
  unitId         String?
  purchasePrice  Decimal? @db.Decimal(10, 2)
  currentStock   Decimal  @default(0) @db.Decimal(10, 3)
  lowStockLevel  Decimal  @default(0) @db.Decimal(10, 3)
  status         String   @default("active") @db.VarChar(20)
  shelfLifeHours Int? // null = normal; set (e.g. 8) = short-life ingredient (dough) with batch + countdown tracking

  // Relations
  category             IngredientCategory?   @relation(fields: [categoryId], references: [id])
  unit                 IngredientUnit?       @relation(fields: [unitId], references: [id])
  recipes              FoodRecipe[]
  stockAdjustments     StockAdjustment[]
  stockTakeItems       StockTakeItem[]
  warehouseStock       WarehouseStock[]
  challanItems         StockChallanItem[]
  demandItems          StockDemandItem[]
  purchaseRequestItems PurchaseRequestItem[]
  stockBatches         StockBatch[]

  @@map("ingredients")
}

model FoodRecipe {
  id               String  @id @default(uuid())
  menuItemId       String
  variantId        String?
  ingredientId     String?
  productionItemId String?
  qtyPerUnit       Decimal @db.Decimal(10, 4)
  usageUnitId      String?

  // Relations
  menuItem       FoodMenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variant        FoodMenuVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  ingredient     Ingredient?      @relation(fields: [ingredientId], references: [id])
  productionItem ProductionItem?  @relation(fields: [productionItemId], references: [id])
  usageUnit      IngredientUnit?  @relation(fields: [usageUnitId], references: [id])

  @@map("food_recipes")
}

model PreMadeFood {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  unit          String?  @db.VarChar(20)
  currentStock  Decimal  @default(0) @db.Decimal(10, 3)
  lowStockLevel Decimal  @default(0) @db.Decimal(10, 3)
  costPerUnit   Decimal? @db.Decimal(10, 2)
  status        String   @default("active") @db.VarChar(20)

  @@map("pre_made_food")
}

model StockAdjustment {
  id           String   @id @default(uuid())
  ingredientId String
  type         String   @db.VarChar(20) // add, deduct, damage, correction
  quantity     Decimal  @db.Decimal(10, 3)
  reason       String?
  adjustedById String?
  warehouseId  String?
  outletId     String?
  date         DateTime @default(now())

  // Relations
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  adjustedBy User?      @relation(fields: [adjustedById], references: [id])
  warehouse  Warehouse? @relation(fields: [warehouseId], references: [id])
  outlet     Outlet?    @relation(fields: [outletId], references: [id])

  @@index([ingredientId])
  @@index([warehouseId, type, date])
  @@index([outletId])
  @@map("stock_adjustments")
}

model StockTake {
  id                 String    @id @default(uuid())
  reference          String?   @unique @db.VarChar(20)
  date               DateTime  @db.Date
  status             String    @default("active") @db.VarChar(20)
  countedBy          String?   @db.VarChar(100)
  totalVarianceValue Decimal   @default(0) @db.Decimal(10, 2)
  notes              String?
  warehouseId        String?
  outletId           String?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())

  // Relations
  items     StockTakeItem[]
  warehouse Warehouse?      @relation(fields: [warehouseId], references: [id])
  outlet    Outlet?         @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("stock_takes")
}

model StockTakeItem {
  id            String   @id @default(uuid())
  stockTakeId   String
  ingredientId  String
  systemQty     Decimal? @db.Decimal(10, 3)
  countedQty    Decimal? @db.Decimal(10, 3)
  variance      Decimal? @db.Decimal(10, 3)
  varianceValue Decimal? @db.Decimal(10, 2)

  // Relations
  stockTake  StockTake  @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("stock_take_items")
}

model Production {
  id               String   @id @default(uuid())
  itemName         String?  @db.VarChar(100)
  quantity         Decimal? @db.Decimal(10, 3)
  unit             String?  @db.VarChar(20)
  producedBy       String?  @db.VarChar(100)
  outletId         String?
  date             DateTime @default(now())
  notes            String?
  shelfLifeMinutes Int?

  // Relations
  outlet           Outlet?  @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("productions")
}

model Transfer {
  id            String   @id @default(uuid())
  fromOutletId  String?
  toOutletId    String?
  itemName      String?  @db.VarChar(100)
  quantity      Decimal? @db.Decimal(10, 3)
  unit          String?  @db.VarChar(20)
  status        String   @default("pending") @db.VarChar(20)
  transferredBy String?  @db.VarChar(100)
  date          DateTime @default(now())
  notes         String?

  // Relations
  fromOutlet Outlet? @relation("TransferFrom", fields: [fromOutletId], references: [id])
  toOutlet   Outlet? @relation("TransferTo", fields: [toOutletId], references: [id])

  @@map("transfers")
}

model WasteRecord {
  id         String   @id @default(uuid())
  itemName   String?  @db.VarChar(100)
  quantity   Decimal? @db.Decimal(10, 3)
  unit       String?  @db.VarChar(20)
  reason     String?
  cost       Decimal? @db.Decimal(10, 2)
  recordedBy String?  @db.VarChar(100)
  outletId   String?
  purchaseId String?
  date       DateTime @default(now())

  // Relations
  outlet     Outlet?   @relation(fields: [outletId], references: [id])
  purchase   Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([purchaseId])
  @@map("waste_records")
}

// =============================================
// PHASE W1: Warehouse Management
// =============================================

model Warehouse {
  id        String        @id @default(uuid())
  name      String        @db.VarChar(100)
  code      String        @unique @db.VarChar(20)
  type      WarehouseType
  outletId  String?
  managerId String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  // Relations
  outlet           Outlet?           @relation(fields: [outletId], references: [id])
  manager          User?             @relation("WarehouseManager", fields: [managerId], references: [id])
  warehouseStock   WarehouseStock[]
  purchases        Purchase[]
  stockAdjustments StockAdjustment[]
  stockTakes       StockTake[]
  challansFrom     StockChallan[]    @relation("ChallanFrom")
  challansTo       StockChallan[]    @relation("ChallanTo")
  demandsRequested StockDemand[]     @relation("DemandRequesting")
  demandsToSupply  StockDemand[]     @relation("DemandSupplying")
  purchaseRequests         PurchaseRequest[]
  stockBatches             StockBatch[]
  productionBatches        ProductionBatch[]
  productionWarehouseStock ProductionWarehouseStock[]

  @@index([outletId, type])
  @@map("warehouses")
}

model ProductionItem {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  unit           String   @db.VarChar(20)
  shelfLifeHours Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  productionBatches        ProductionBatch[]
  productionWarehouseStock ProductionWarehouseStock[]
  foodRecipes              FoodRecipe[]

  @@map("production_items")
}

model ProductionBatch {
  id               String   @id @default(uuid())
  productionItemId String
  warehouseId      String
  batchQty         Decimal  @db.Decimal(10, 3)
  remainingQty     Decimal  @db.Decimal(10, 3)
  shelfLifeMinutes Int?
  unitCost         Decimal? @db.Decimal(10, 2)
  createdAt        DateTime @default(now())

  productionItem ProductionItem @relation(fields: [productionItemId], references: [id])
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([productionItemId, warehouseId])
  @@map("production_batches")
}

model ProductionWarehouseStock {
  id               String   @id @default(uuid())
  productionItemId String
  warehouseId      String
  currentStock     Decimal  @default(0) @db.Decimal(10, 3)
  updatedAt        DateTime @updatedAt

  productionItem ProductionItem @relation(fields: [productionItemId], references: [id])
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([productionItemId, warehouseId])
  @@map("production_warehouse_stock")
}

model StockBatch {
  id           String    @id @default(uuid())
  warehouseId  String
  ingredientId String
  purchaseId   String?
  batchQty         Decimal   @db.Decimal(10, 3)
  remainingQty     Decimal   @db.Decimal(10, 3)
  expiryDate       DateTime? @db.Date
  shelfLifeMinutes Int? // per-batch expiry override (minutes from createdAt); null = use ingredient.shelfLifeHours
  unitCost         Decimal?  @db.Decimal(10, 2) // cost per produced unit = (sum of consumed ingredient costs) / qty; used to value waste
  createdAt        DateTime  @default(now())

  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  purchase   Purchase?  @relation(fields: [purchaseId], references: [id])

  @@index([warehouseId, ingredientId])
  @@index([ingredientId])
  @@index([expiryDate])
  @@index([purchaseId])
  @@map("stock_batches")
}

model WarehouseStock {
  id            String   @id @default(uuid())
  warehouseId   String
  ingredientId  String
  currentStock  Decimal  @default(0) @db.Decimal(10, 3)
  lowStockLevel Decimal  @default(0) @db.Decimal(10, 3)
  updatedAt     DateTime @updatedAt

  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([warehouseId, ingredientId])
  @@map("warehouse_stock")
}

model StockChallan {
  id              String        @id @default(uuid())
  challanNo       String        @unique @db.VarChar(30)
  fromWarehouseId String
  toWarehouseId   String
  status          ChallanStatus @default(PENDING)
  notes           String?
  shippingCost    Decimal?      @db.Decimal(10, 2)
  miscAmount      Decimal?      @db.Decimal(10, 2)
  dispatchedAt    DateTime?
  receivedAt      DateTime?
  dispatchedById  String?
  receivedById    String?
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  fromWarehouse Warehouse          @relation("ChallanFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse          @relation("ChallanTo", fields: [toWarehouseId], references: [id])
  dispatchedBy  User?              @relation("ChallanDispatched", fields: [dispatchedById], references: [id])
  receivedBy    User?              @relation("ChallanReceived", fields: [receivedById], references: [id])
  createdBy     User?              @relation("ChallanCreated", fields: [createdById], references: [id])
  items         StockChallanItem[]
  demand        StockDemand?

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_challans")
}

model StockChallanItem {
  id           String   @id @default(uuid())
  challanId    String
  ingredientId String
  qty          Decimal  @db.Decimal(10, 3)
  receivedQty  Decimal? @db.Decimal(10, 3)
  wasteQty     Decimal? @db.Decimal(10, 3)
  wasteReason  String?

  challan    StockChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  ingredient Ingredient   @relation(fields: [ingredientId], references: [id])

  @@map("stock_challan_items")
}

model StockDemand {
  id              String       @id @default(uuid())
  demandNo        String       @unique @db.VarChar(30)
  requestingWHId  String
  supplyingWHId   String
  status          DemandStatus @default(PENDING)
  notes           String?
  rejectionReason String?
  challanId       String?      @unique
  approvedAt      DateTime?
  fulfilledAt     DateTime?
  rejectedAt      DateTime?
  requestedById   String?
  approvedById    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  requestingWH Warehouse         @relation("DemandRequesting", fields: [requestingWHId], references: [id])
  supplyingWH  Warehouse         @relation("DemandSupplying", fields: [supplyingWHId], references: [id])
  requestedBy  User?             @relation("DemandRequested", fields: [requestedById], references: [id])
  approvedBy   User?             @relation("DemandApproved", fields: [approvedById], references: [id])
  challan      StockChallan?     @relation(fields: [challanId], references: [id])
  items        StockDemandItem[]

  @@index([requestingWHId])
  @@index([supplyingWHId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_demands")
}

model StockDemandItem {
  id             String   @id @default(uuid())
  demandId       String
  ingredientId   String
  requestedQty   Decimal  @db.Decimal(10, 3)
  approvedQty    Decimal? @db.Decimal(10, 3)
  stockAtRequest Decimal? @db.Decimal(10, 3)

  demand     StockDemand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  ingredient Ingredient  @relation(fields: [ingredientId], references: [id])

  @@map("stock_demand_items")
}

// =============================================
// PHASE 5: Orders & POS
// =============================================

enum OrderType {
  DINE_IN    @map("Dine In")
  TAKE_AWAY  @map("Take Away")
  DELIVERY   @map("Delivery")
  ONLINE     @map("Online")
  SELF_ORDER @map("Self Order")
  FOODPANDA  @map("Foodpanda")
  WALKIN     @map("Walk-in")
}

enum OrderStatus {
  PENDING   @map("pending")
  PREPARING @map("preparing")
  READY     @map("ready")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
  SCHEDULED @map("scheduled")
}

enum WarehouseType {
  MAIN    @map("main")
  BRANCH  @map("branch")
  KITCHEN @map("kitchen")
}

enum ChallanStatus {
  PENDING    @map("pending")
  DISPATCHED @map("dispatched")
  RECEIVED   @map("received")
  CANCELLED  @map("cancelled")
}

enum DemandStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  FULFILLED @map("fulfilled")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @db.VarChar(20)
  customerId      String?
  customerName    String?     @db.VarChar(100)
  phone           String?     @db.VarChar(20)
  type            OrderType   @default(WALKIN)
  subtotal        Decimal     @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentMethod   String?
  date            DateTime    @db.Date
  time            String?     @db.VarChar(20)
  staffId         String?
  staffName       String?     @db.VarChar(100)
  tableNumber     Int?
  deliveryAddress String?
  riderId         String?
  outletId        String?
  // Future Sale fields
  isFutureSale    Boolean     @default(false)
  scheduledDate   DateTime?   @db.Date
  scheduledTime   String?     @db.VarChar(20)
  futureNotes     String?
  advancePayment  Decimal     @default(0) @db.Decimal(10, 2)
  // Enhanced POS fields
  isUrgent        Boolean     @default(false)
  customerType    String?     @db.VarChar(20) // walk-in, regular, corporate, vip
  orderSource     String?     @db.VarChar(20) // pos, self-order, website, foodpanda, phone
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  customer      Customer?              @relation(fields: [customerId], references: [id])
  staff         User?                  @relation(fields: [staffId], references: [id])
  rider         DeliveryRider?         @relation(fields: [riderId], references: [id])
  outlet        Outlet?                @relation("OrderOutlet", fields: [outletId], references: [id])
  items         OrderItem[]
  modifications OrderModificationLog[]
  deliveries    DeliveryAssignment[]
  loyaltyTx     LoyaltyTransaction[]

  @@index([createdAt])
  @@index([status])
  @@index([type])
  @@index([date])
  @@index([customerId])
  @@index([riderId])
  @@index([outletId, createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  menuItemId  String?
  variantId   String?
  name        String   @db.VarChar(200)
  price       Decimal  @db.Decimal(10, 2)
  qty         Int
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  modifiers   String[]
  cookingTime Int?
  notes       String?

  // Relations
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem FoodMenuItem? @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderModificationLog {
  id        String   @id @default(uuid())
  orderId   String
  action    String   @db.VarChar(30) // item_added, item_removed, qty_changed, etc.
  detail    String?
  staff     String?  @db.VarChar(100)
  timestamp DateTime @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_modification_logs")
}

model Kitchen {
  id                 String   @id @default(uuid())
  name               String   @db.VarChar(100)
  assignedCategories String[]
  status             String   @default("active") @db.VarChar(20)

  @@map("kitchens")
}

// =============================================
// PHASE 6: Customers & Loyalty
// =============================================

model Customer {
  id              String    @id @default(uuid())
  name            String    @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  address         String?
  customerType    String    @default("walk-in") @db.VarChar(20) // walk-in, regular, corporate, vip
  loyaltyPoints   Int       @default(0)
  customPriceList String?   @db.VarChar(50)
  totalOrders     Int       @default(0)
  totalSpent      Decimal   @default(0) @db.Decimal(12, 2)
  outstandingDue  Decimal   @default(0) @db.Decimal(10, 2)
  lastOrder       DateTime? @db.Date
  createdAt       DateTime  @default(now())
  outletId        String?   @db.VarChar(36)

  // Relations
  outlet        Outlet?        @relation(fields: [outletId], references: [id])
  orders        Order[]
  loyaltyMember LoyaltyMember?

  @@map("customers")
}

model LoyaltySettings {
  id              String  @id @default(uuid())
  outletId        String?
  pointsPerAmount Int     @default(1)
  amountPerPoint  Decimal @default(100) @db.Decimal(10, 2)
  signupBonus     Int     @default(100)
  birthdayBonus   Int     @default(50)
  tiers           Json    @default("[]")

  // Relations
  outlet Outlet? @relation(fields: [outletId], references: [id])

  @@map("loyalty_settings")
}

model LoyaltyMember {
  id              String   @id @default(uuid())
  customerId      String   @unique
  phone           String?  @db.VarChar(20)
  totalPoints     Int      @default(0)
  availablePoints Int      @default(0)
  tier            String   @default("Bronze") @db.VarChar(30)
  joinedDate      DateTime @default(now()) @db.Date

  // Relations
  customer     Customer             @relation(fields: [customerId], references: [id])
  transactions LoyaltyTransaction[]

  @@map("loyalty_members")
}

model LoyaltyReward {
  id             String  @id @default(uuid())
  name           String? @db.VarChar(100)
  pointsRequired Int
  type           String  @db.VarChar(30) // freeItem, percentDiscount, fixedDiscount
  value          String? @db.VarChar(100)
  isActive       Boolean @default(true)

  @@map("loyalty_rewards")
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  memberId    String
  type        String   @db.VarChar(10) // earn, redeem
  points      Int
  description String?
  orderId     String?
  date        DateTime @default(now()) @db.Date

  // Relations
  member LoyaltyMember @relation(fields: [memberId], references: [id])
  order  Order?        @relation(fields: [orderId], references: [id])

  @@map("loyalty_transactions")
}

// =============================================
// PHASE 7: Financial
// =============================================

model Supplier {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  company        String?  @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(100)
  totalPurchases Decimal  @default(0) @db.Decimal(12, 2)
  totalDue       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  // Relations
  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id            String   @id @default(uuid())
  supplierId    String?
  warehouseId   String?
  outletId      String?
  invoiceNumber String?  @db.VarChar(30)
  items         Json // [{name, qty, unit, price, total}]
  subtotal      Decimal? @db.Decimal(10, 2)
  tax           Decimal? @db.Decimal(10, 2)
  shippingCost  Decimal? @db.Decimal(10, 2)
  miscAmount    Decimal? @db.Decimal(10, 2)
  total         Decimal? @db.Decimal(10, 2)
  paid          Decimal  @default(0) @db.Decimal(10, 2)
  due           Decimal  @default(0) @db.Decimal(10, 2)
  status        String   @default("pending") @db.VarChar(20)
  date          DateTime @default(now()) @db.Date
  notes         String?
  createdAt     DateTime @default(now())

  purchaseRequestId String? @unique
  createdById       String?

  // Relations
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse?       @relation(fields: [warehouseId], references: [id])
  outlet          Outlet?          @relation(fields: [outletId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  createdBy       User?            @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  stockBatches    StockBatch[]
  wasteRecords    WasteRecord[]

  @@index([outletId])
  @@map("purchases")
}

model Expense {
  id            String   @id @default(uuid())
  category      String?  @db.VarChar(50)
  description   String?
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String?
  reference     String?  @db.VarChar(50)
  receipt       Boolean  @default(false)
  date          DateTime @default(now()) @db.Date
  recordedBy    String?  @db.VarChar(100)
  outletId      String?
  createdAt     DateTime @default(now())

  // Relations
  outlet        Outlet?  @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("expenses")
}

// =============================================
// PHASE 8: Delivery
// =============================================

model DeliveryRider {
  id               String  @id @default(uuid())
  userId           String? @unique // links to User account (role=Rider)
  name             String  @db.VarChar(100)
  phone            String? @db.VarChar(20)
  isAvailable      Boolean @default(true)
  activeDeliveries Int     @default(0)
  status           String  @default("available") @db.VarChar(20) // available, on_delivery, offline

  // Relations
  user       User?                @relation(fields: [userId], references: [id])
  orders     Order[]
  deliveries DeliveryAssignment[]

  @@map("delivery_riders")
}

model DeliveryAssignment {
  id              String    @id @default(uuid())
  orderId         String
  riderId         String
  status          String    @default("pending") @db.VarChar(20) // pending, accepted, dispatched, delivered, returned
  assignedAt      DateTime  @default(now())
  acceptedAt      DateTime?
  deliveredAt     DateTime?
  estimatedTime   Int? // minutes
  customerAddress String?
  customerPhone   String?   @db.VarChar(20)
  notes           String?
  // Amount collection
  amountToCollect Decimal?  @db.Decimal(10, 2) // order total (cash on delivery)
  collectedAt     DateTime? // when manager collected cash from rider
  collectedBy     String?   @db.VarChar(100) // name of manager who collected

  // Relations
  order Order         @relation(fields: [orderId], references: [id])
  rider DeliveryRider @relation(fields: [riderId], references: [id])

  @@index([riderId, status, deliveredAt])
  @@index([orderId])
  @@index([status])
  @@map("delivery_assignments")
}

// =============================================
// PHASE 9: HR & Staff
// =============================================

model AttendanceRecord {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserAttendance", fields: [userId], references: [id])
  outletId  String
  outlet    Outlet    @relation(fields: [outletId], references: [id])
  date      String    // "YYYY-MM-DD" — one record per person per day
  clockIn   DateTime?
  clockOut  DateTime?
  status    String    @default("present") // present | late | absent
  overtimeMinutes Int @default(0) // minutes clocked out past the scheduled shift end
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, date])
  @@map("attendance_records")
}

model LeaveRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLeaves", fields: [userId], references: [id])
  outletId     String
  outlet       Outlet   @relation(fields: [outletId], references: [id])
  leaveType    String   // casual | sick | annual | emergency
  startDate    String   // "YYYY-MM-DD"
  endDate      String
  totalDays    Int
  reason       String
  status       String   @default("pending") // pending | approved | rejected
  reviewedById String?
  reviewedBy   User?    @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedOn   String?
  reviewNote   String?
  appliedOn    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("leave_requests")
}

model LeaveBalance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  year       Int
  annual     Int      @default(14)
  annualUsed Int      @default(0)
  sick       Int      @default(6)
  sickUsed   Int      @default(0)
  casual     Int      @default(6)
  casualUsed Int      @default(0)
  halfday    Int      @default(10)
  halfdayUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, year])
  @@map("leave_balances")
}

model StaffSchedule {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation("UserSchedules", fields: [userId], references: [id])
  outletId  String
  outlet    Outlet          @relation(fields: [outletId], references: [id])
  weekStart String          // "YYYY-MM-DD" always a Monday
  status    String          @default("draft") // draft | published
  shifts    ScheduleShift[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, weekStart])
  @@map("staff_schedules")
}

model ScheduleShift {
  id         String        @id @default(cuid())
  scheduleId String
  schedule   StaffSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dayIndex   Int           // 0=Mon, 1=Tue, ..., 6=Sun
  shiftType  String        // morning | evening | night | off
  startTime  String?       // "09:00"
  endTime    String?       // "17:00"

  @@map("schedule_shifts")
}

model Shift {
  id               String    @id @default(uuid())
  shiftNumber      String?   @unique @db.VarChar(20)
  cashierId        String?
  cashierName      String?   @db.VarChar(100)
  outletId         String?
  openedAt         DateTime
  closedAt         DateTime?
  openingCash      Decimal?  @db.Decimal(10, 2)
  closingCash      Decimal?  @db.Decimal(10, 2)
  status           String    @default("open") @db.VarChar(10) // open, closed
  totalSales       Decimal   @default(0) @db.Decimal(10, 2)
  totalCashSales   Decimal   @default(0) @db.Decimal(10, 2)
  totalCardSales   Decimal   @default(0) @db.Decimal(10, 2)
  totalOnlineSales Decimal   @default(0) @db.Decimal(10, 2)
  orderCount       Int       @default(0)
  cancelledOrders  Int       @default(0)
  totalExpenses    Decimal   @default(0) @db.Decimal(10, 2)
  expectedCash     Decimal   @default(0) @db.Decimal(10, 2)
  cashDifference   Decimal?  @db.Decimal(10, 2)
  notes            String?

  // Relations
  cashier User?   @relation(fields: [cashierId], references: [id])
  outlet  Outlet? @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("shifts")
}

// =============================================
// PHASE 10: Advanced
// =============================================

model Deal {
  id                   String    @id @default(uuid())
  name                 String    @db.VarChar(100)
  description          String?
  type                 String    @db.VarChar(30) // percentage, combo, buyXgetY, timeBased, optionCombo
  discountPercent      Decimal?  @db.Decimal(5, 2)
  applicableItems      String[]
  applicableCategories String[]
  comboItems           Json? // [{itemId, qty}]
  comboPrice           Decimal?  @db.Decimal(10, 2)
  buyQty               Int?
  getQty               Int?
  buyItemId            String?
  getItemId            String?
  startTime            String?   @db.VarChar(10)
  endTime              String?   @db.VarChar(10)
  timeDiscountPercent  Decimal?  @db.Decimal(5, 2)
  optionGroups         Json? // [{id, label, allowedItems[], maxSelections}]
  dealPrice            Decimal?  @db.Decimal(10, 2)
  validFrom            DateTime? @db.Date
  validTo              String?   @db.VarChar(20) // 'always' or date string
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())

  @@map("deals")
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique @db.VarChar(30)
  type           String    @db.VarChar(20) // percentage, fixed
  value          Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal   @default(0) @db.Decimal(10, 2)
  maxDiscount    Decimal?  @db.Decimal(10, 2)
  usageLimit     Int       @default(0)
  usedCount      Int       @default(0)
  validFrom      DateTime? @db.Date
  validTo        DateTime? @db.Date
  isActive       Boolean   @default(true)
  applicableTo   String    @default("all") @db.VarChar(20)
  createdAt      DateTime  @default(now())

  @@map("coupons")
}

model Reservation {
  id              String   @id @default(uuid())
  customerName    String   @db.VarChar(100)
  customerPhone   String?  @db.VarChar(20)
  date            DateTime @db.Date
  time            String   @db.VarChar(10)
  guestCount      Int      @default(1)
  tableId         String?
  tableNumber     String?  @db.VarChar(10)
  status          String   @default("pending") @db.VarChar(20) // pending, confirmed, seated, completed, cancelled, noShow
  specialRequests String?
  source          String?  @db.VarChar(20) // phone, walkin, online
  outletId        String?
  createdAt       DateTime @default(now())

  // Relations
  table  RestaurantTable? @relation(fields: [tableId], references: [id])
  outlet Outlet?          @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("reservations")
}

model RestaurantTable {
  id             String  @id @default(uuid())
  number         String  @db.VarChar(10)
  capacity       Int     @default(4)
  floor          String? @db.VarChar(50)
  shape          String? @db.VarChar(20) // square, round, rectangle
  status         String  @default("available") @db.VarChar(20)
  currentOrderId String?
  reservationId  String?
  outletId       String?

  // Relations
  reservations Reservation[]
  outlet       Outlet?       @relation(fields: [outletId], references: [id])

  @@unique([outletId, number])
  @@index([outletId])
  @@map("restaurant_tables")
}

model MealType {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(50)
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now())

  @@map("meal_types")
}

model SmsHistory {
  id        String   @id @default(uuid())
  recipient String?  @db.VarChar(20)
  message   String?
  status    String?  @db.VarChar(20)
  sentAt    DateTime @default(now())

  @@map("sms_history")
}

// =============================================
// PHASE 11: Purchase Requests
// =============================================

model PurchaseRequest {
  id          String  @id @default(uuid())
  requestNo   String  @unique @db.VarChar(30)
  status      String  @default("PENDING") @db.VarChar(20)
  warehouseId String
  notes       String?

  requestedById String
  createdAt     DateTime @default(now())

  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  rejectedAt      DateTime?

  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id])
  requestedBy User                  @relation("PurchaseRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?                 @relation("PurchaseApprovedBy", fields: [approvedById], references: [id])
  items       PurchaseRequestItem[]
  purchase    Purchase?

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id           String   @id @default(uuid())
  requestId    String
  ingredientId String
  requestedQty Decimal  @db.Decimal(10, 3)
  approvedQty  Decimal? @db.Decimal(10, 3)

  request    PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ingredient Ingredient      @relation(fields: [ingredientId], references: [id])

  @@unique([requestId, ingredientId])
  @@map("purchase_request_items")
}
