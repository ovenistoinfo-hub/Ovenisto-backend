{
  "name": "ovenisto-backend",
  "version": "1.0.0",
  "description": "Backend API for Ovenisto POS System",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "build": "prisma generate && tsc",
    "start": "node scripts/db-push.mjs && node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "node scripts/db-push.mjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-warehouses": "tsx src/seeds/warehouseMigration.ts",
    "db:seed-outlet-stock": "tsx src/seeds/outletStockBackfill.ts",
    "db:seed-outlet-shifttable": "tsx src/seeds/outletShiftTableBackfill.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "prisma": "^5.10.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.14",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pos",
    "restaurant",
    "backend",
    "api",
    "typescript",
    "express",
    "prisma"
  ],
  "author": "Ovenisto",
  "license": "MIT"
}
