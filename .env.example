# Get your connection string from Supabase/Neon dashboard
# For Supabase: Use "Transaction" pooler connection string
# For Neon: Use the pooled connection string

DATABASE_URL="postgresql://user:password@host:5432/ovenisto?schema=public"

# Server
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS (Frontend URL)
CORS_ORIGIN=http://localhost:8080
